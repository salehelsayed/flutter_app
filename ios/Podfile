platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Workaround: xcodeproj gem doesn't yet support Xcode 26 object version 70
require 'xcodeproj'
unless Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION.key?(70)
  patched = Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION.dup
  patched[70] = 'Xcode 16.0'
  Xcodeproj::Constants.send(:remove_const, :COMPATIBILITY_VERSION_BY_OBJECT_VERSION)
  Xcodeproj::Constants.const_set(:COMPATIBILITY_VERSION_BY_OBJECT_VERSION, patched.freeze)
end

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Keep the local gomobile framework in sync with Swift bridge calls so
  # simulator builds fail early with a clear regeneration step instead of an
  # unresolved symbol deeper in Xcode compilation.
  script_phase(
    :name => 'Ensure GoMknoon iOS Bindings',
    :execution_position => :before_compile,
    :shell_path => '/bin/bash',
    :script => <<-'SCRIPT'
"${PODS_ROOT}/../../scripts/ensure_go_ios_bindings.sh"
SCRIPT
  )

  # Go native library (built via: cd go-mknoon && make ios)
  if File.exist?(File.join(__dir__, 'Runner', 'GoMknoon.xcframework'))
    pod 'GoMknoon', :path => '.'
  end
  target 'Share Extension' do
    inherit! :search_paths
  end
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # The share extension imports the receive_sharing_intent framework, but it
  # inherits search paths instead of owning the Flutter pod directly. Xcode's
  # module verifier needs explicit access to the Flutter and plugin frameworks
  # to resolve transitive module dependencies during extension compilation.
  %w[debug release profile].each do |config|
    xcconfig_path = File.join(
      __dir__,
      'Pods',
      'Target Support Files',
      'Pods-Share Extension',
      "Pods-Share Extension.#{config}.xcconfig",
    )
    next unless File.exist?(xcconfig_path)

    content = File.read(xcconfig_path)
    verifier_flags = 'OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/Flutter" "-F${PODS_CONFIGURATION_BUILD_DIR}/receive_sharing_intent"'
    next if content.include?(verifier_flags)

    File.open(xcconfig_path, 'a') do |file|
      file.puts verifier_flags
    end
  end
end
