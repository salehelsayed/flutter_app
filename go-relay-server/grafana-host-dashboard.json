      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}",
          "legendFormat": "free",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "collapsed": false,
