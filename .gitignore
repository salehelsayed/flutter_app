#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter plugins file
.flutter-plugins

# Code generation (build_runner, freezed, json_serializable)
*.g.dart
*.freezed.dart
*.mocks.dart

# Environment files with secrets
.env
.env.*

# Firebase config files (contain API keys)
GoogleService-Info.plist
google-services.json

# Flutter Version Manager
.fvm/

# Generated localization
*.arb.dart

# Heap dumps
*.hprof

# Node.js
node_modules/
package-lock.json

# Generated JS build outputs
core_lib_js/dist/
core_lib_js/node_modules/
m3-libp2p-1/core_lib_js/dist/
m3-libp2p-1/core_lib_js/node_modules/

# Local libp2p credentials
m3-libp2p-1/Creds_User_*.txt

# Source maps
*.js.map

# Temporary/working directories
download/
maker_workspace/

# TypeScript source files (keeping compiled JS only)
*.ts
!*.d.ts

# Screenshots (macOS naming pattern)
Screenshot*.png

# Root-level Node.js files (for non-JS projects)
/package.json

# QR generation test artifacts
m2-qr-generation/

# UI branch working directories
UI-1-2/

# Temporary maker scripts
maker_*.sh

# CocoaPods lock file (regenerated on pod install)
macos/Podfile.lock
ios/Podfile.lock

# Go mobile build outputs (regenerated via `make all`)
ios/Runner/GoMknoon.xcframework/
macos/Runner/GoMknoon.xcframework/
android/app/libs/*.aar
android/app/libs/*.jar
