ios/Podfile.lock

# Go mobile build outputs (regenerated via `make all`)
ios/Runner/GoMknoon.xcframework/
macos/Runner/GoMknoon.xcframework/
android/app/libs/*.aar
android/app/libs/*.jar

# Private keys
*.pem

# Xcode DerivedData / index / module caches accidentally committed at the repo root
Index.noindex/
ModuleCache.noindex/
SDKStatCaches.noindex/

# iOS build outputs (Flutter writes the iOS archive/ipa here, separate from the root /build/)
ios/build/

# Local distribution outputs
/dist/

# Local test/regression run logs
.codex-test-logs/
.full_regression_logs/

# Local sandbox / build caches — never commit these to git.
# All entries below hold per-developer state that gets regenerated on every
# build and embeds machine-specific identifiers (absolute paths, nanosecond
# timestamps, per-host content hashes, telemetry session ids). Tracking any
# of them produces constant merge churn and drowns real diffs.
#  - .codex-bin/                  per-developer Flutter shim w/ hardcoded FLUTTER_ROOT
#  - .codex-gocache/              Go build cache shards
#  - .codex-home/                 sandbox HOME for dart/flutter analyze (analysis-driver
#                                 binary scratch, telemetry session, per-developer CLIENT_ID)
#  - CompilationCache.noindex/    Xcode compilation cache
#  - Logs/                        Xcode .xcactivitylog build logs
#  - output/                      Playwright UI-test screenshots / .yml snapshots
#  - .playwright-cli/             More Playwright UI-test snapshots
.codex-bin/
.codex-gocache/
.codex-home/
CompilationCache.noindex/
Logs/
output/
.playwright-cli/

# Claude Code scheduler state
.claude/scheduled_tasks.lock
