+    if (inFlight.isEmpty) {
+      break;
+    }
+
+    await Future.any(inFlight);
+  }
+
+  await completionQueue.flush();
+  final uncaughtError = fatalError;
+  if (uncaughtError != null) {
+    Error.throwWithStackTrace(uncaughtError.error, uncaughtError.stackTrace);
